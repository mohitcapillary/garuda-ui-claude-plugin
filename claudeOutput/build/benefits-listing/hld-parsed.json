  "apis": [
    {
      "name": "getBenefits",
      "status": "confirmed",
      "endpoint": "/incentives/api/v1/benefits",
      "method": "GET",
      "baseUrlKey": "endpoints.incentives_endpoint",
      "requestPayload": {
        "page": "integer (1-based)",
        "size": "integer (default 20)",
        "sort": "string: updated_at|start_date|end_date",
        "order": "string: asc|desc",
        "search": "string",
        "status[]": "string multi-value: active|upcoming|ended|draft|awaiting_approval|rejected",
        "category_id[]": "integer multi-value",
        "program_id[]": "integer multi-value",
        "start_date": "ISO8601",
        "end_date": "ISO8601",
        "updated_by[]": "integer multi-value user IDs",
        "updated_at": "string preset: today|yesterday|last_7d|last_30d|last_90d",
        "tier_event[]": "string multi-value: upgrade|downgrade|renew"
      },
      "responsePayload": {
        "data": [
          {
            "id": "integer",
            "external_id": "string",
            "name": "string",
            "description": "string",
            "status": "string",
            "start_date": "ISO8601",
            "end_date": "ISO8601",
            "program_id": "integer",
            "program_name": "string",
            "category_id": "integer",
            "category_name": "string",
            "last_updated_at": "ISO8601",
            "last_updated_by": { "id": "integer", "name": "string" },
            "tier_event": "string"
          }
        ],
        "pagination": {
          "page": "integer",
          "size": "integer",
          "total": "integer"
        }
      },
      "errors": [
        { "code": 400, "name": "BadRequest" },
        { "code": 401, "name": "Unauthorized" },
        { "code": 403, "name": "Forbidden" },
        { "code": 404, "name": "NotFound" },
        { "code": 500, "name": "InternalServerError" }
      ]
    },
    {
      "name": "getBenefitsCategories",
      "status": "confirmed",
      "endpoint": "/incentives/api/v1/benefits/categories",
      "method": "GET",
      "notes": "Already exists in api.js — reused for filter panel Category options"
    },
    {
      "name": "getPrograms",
      "status": "confirmed",
      "notes": "makeSelectPrograms() from Cap slice — no new API call needed"
    }
  ],
  "redux": {
    "injectKey": "${CURRENT_APP_NAME}-benefits-list",
    "storeShape": "fromJS({ benefits: [], benefitsStatus: INITIAL, error: null, totalElements: 0, totalPages: 0 })",
    "actions": [
      { "type": "GET_BENEFITS_LIST_REQUEST", "creator": "getBenefitsList(searchTerm, filters, pagination, sortBy, sortOrder)" },
      { "type": "GET_BENEFITS_LIST_SUCCESS", "creator": "getBenefitsListSuccess(data, pagination)" },
      { "type": "GET_BENEFITS_LIST_FAILURE", "creator": "getBenefitsListFailure(error)" },
      { "type": "SET_BENEFITS_STATUS", "creator": "setBenefitsStatus(status)" },
      { "type": "CLEAR_BENEFITS_LIST_DATA", "creator": "clearBenefitsListData()" }
    ],
    "selectors": [
      { "name": "makeSelectBenefits()", "path": "benefits", "returns": "Array<BenefitRecord>" },
      { "name": "makeSelectBenefitsStatus()", "path": "benefitsStatus", "returns": "string" },
      { "name": "makeSelectBenefitsError()", "path": "error", "returns": "object|null" },
      { "name": "makeSelectBenefitsTotalElements()", "path": "totalElements", "returns": "number" },
      { "name": "makeSelectBenefitsTotalPages()", "path": "totalPages", "returns": "number" }
    ],
    "sagas": [
      { "name": "getBenefitsListSaga", "trigger": "GET_BENEFITS_LIST_REQUEST", "concurrency": "takeLatest" },
      { "name": "watchForGetBenefitsListSaga", "trigger": "root watcher", "concurrency": "takeLatest" }
    ]
  },
