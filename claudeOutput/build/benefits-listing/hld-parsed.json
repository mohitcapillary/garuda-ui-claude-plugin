  "apis": [
    {
      "name": "getBenefitsList",
      "status": "ASSUMED",
      "endpoint": "GET /loyalty/api/v1/benefits",
      "method": "GET",
      "requestPayload": {
        "page": 0,
        "size": 10,
        "searchText": "string (optional)",
        "status": ["Awaiting Approval", "Draft", "Upcoming", "Live", "Stopped"],
        "programName": ["string"],
        "category": ["string"],
        "startDate": "ISO 8601 datetime (optional)",
        "endDate": "ISO 8601 datetime (optional)",
        "lastModifiedFrom": "ISO 8601 datetime (optional)",
        "lastModifiedTo": "ISO 8601 datetime (optional)",
        "lastUpdatedPreset": "TODAY | YESTERDAY | LAST_7_DAYS | LAST_30_DAYS | LAST_90_DAYS (optional)",
        "updatedBy": ["string"],
        "groupBy": "CATEGORY | PROGRAM_TYPE | SPECIFIC (optional)"
      },
      "responsePayload": {
        "data": {
          "content": [
            {
              "id": "string",
              "externalId": "string",
              "name": "string",
              "description": "string",
              "status": "Awaiting Approval | Draft | Upcoming | Live | Stopped",
              "programName": "string",
              "category": "string",
              "startDate": "ISO 8601 datetime",
              "endDate": "ISO 8601 datetime",
              "lastModifiedDate": "ISO 8601 datetime",
              "lastModifiedBy": "string"
            }
          ],
          "totalPages": 5,
          "totalElements": 48
        }
      },
      "validation": "page>=0, size 1-100, valid status values, startDate before endDate",
      "errors": ["400 INVALID_FILTER_PARAMS", "401 UNAUTHORIZED", "403 FORBIDDEN", "404 NOT_FOUND", "500 INTERNAL_SERVER_ERROR"]
    },
    {
      "name": "getBenefitPrograms",
      "status": "ASSUMED",
      "endpoint": "GET /loyalty/api/v1/programs",
      "method": "GET",
      "requestPayload": {},
      "responsePayload": { "data": [{ "id": "string", "name": "string" }] },
      "validation": "Standard",
      "errors": ["400", "401", "403", "500"]
    },
    {
      "name": "getBenefitCategories",
      "status": "ASSUMED",
      "endpoint": "GET /loyalty/api/v1/benefit-categories",
      "method": "GET",
      "requestPayload": {},
      "responsePayload": { "data": [{ "id": "string", "label": "string" }] },
      "validation": "Standard",
      "errors": ["400", "401", "403", "500"]
    }
  ],
  "redux": {
    "storeShape": "${CURRENT_APP_NAME}-benefits-listing",
    "actions": [
      "GET_BENEFITS_LIST_REQUEST", "GET_BENEFITS_LIST_SUCCESS", "GET_BENEFITS_LIST_FAILURE",
      "SET_ACTIVE_FILTERS", "CLEAR_ACTIVE_FILTERS", "CLEAR_SEARCH",
      "SET_BENEFITS_STATUS", "GET_PROGRAMS_REQUEST", "GET_PROGRAMS_SUCCESS",
      "GET_CATEGORIES_REQUEST", "GET_CATEGORIES_SUCCESS", "CLEAR_DATA"
    ],
    "selectors": [
      "makeSelectBenefits", "makeSelectBenefitsStatus", "makeSelectBenefitsError",
      "makeSelectTotalPages", "makeSelectTotalElements", "makeSelectActiveFilters",
      "makeSelectPrograms", "makeSelectCategories"
    ],
    "sagas": [
      "getBenefitsListSaga (takeLatest, GET_BENEFITS_LIST_REQUEST)",
      "getProgramsSaga (takeLatest, GET_PROGRAMS_REQUEST)",
      "getCategoriesSaga (takeLatest, GET_CATEGORIES_REQUEST)"
    ]
  },
  "validation": {
    "clientSide": [
      "Search input minimum 1 character before debounce fires",
      "Duration start date must be before or equal to end date",
      "Duration end date must be after or equal to start date"
    ],
    "serverSide": "Saga wraps API call in try/catch; errors array check dispatches failure; non-2xx throws dispatch failure"
  },
