{
  "feature": "benefits-listing",
  "featureName": "Benefits Listing",
  "prdSource": "claudeOutput/filteredPrd/benefits-listing-spec.md",
  "inScope": [
    "Flat benefits list with search (by name, description, ID, external ID), filter panel, and sortable columns",
    "Infinite scroll (page size 20, IntersectionObserver)",
    "6-column table: Name, Status, Duration, Program name, Category, Updated at",
    "Status badge (6 values) with computed client-side secondary status text",
    "Filter panel (Status, Category, Program, Duration, Last updated by, Last updated at, Tier event)",
    "Row click navigates to /benefits/:benefitId",
    "Loading (skeleton), empty (no results), empty (filtered), and error states",
    "Independent /benefits route, sibling to BenefitsSettings"
  ],
  "outOfScope": [
    "Summary count cards",
    "Benefit creation flow",
    "Grouped-by-category listing view",
    "CSV / config download / export",
    "RBAC / permission gating",
    "Tier-event grouped view",
    "Tier/Subscription as a table column"
  ],
  "newComponents": [
    { "name": "BenefitsList", "tier": "page", "location": "app/components/pages/BenefitsList/", "purpose": "Root container; Redux-connected, injects reducer + saga, renders toolbar + table" },
    { "name": "BenefitsListTable", "tier": "molecule", "location": "app/components/molecules/BenefitsListTable/", "purpose": "CapTable wrapper; renders 6-column benefit rows with status badges, sort icons, and row-click navigation" },
    { "name": "BenefitsListFilterPanel", "tier": "molecule", "location": "app/components/molecules/BenefitsListFilterPanel/", "purpose": "Slide-out filter panel; 7 filter controls" },
    { "name": "BenefitStatusTag", "tier": "atom", "location": "app/components/atoms/BenefitStatusTag/", "purpose": "Status badge (coloured dot + label) + secondary status text computed from date fields" }
  ],
  "modifiedComponents": [
    { "name": "app/components/pages/App/routes.js", "location": "app/components/pages/App/routes.js", "change": "Add /benefits route entry pointing to BenefitsList Loadable" }
  ],
  "newReduxDomains": [
    { "domain": "benefits-list", "injectKey": "${CURRENT_APP_NAME}-benefits-list", "reducer": "BenefitsList/reducer.js", "saga": "BenefitsList/saga.js", "purpose": "Stores benefits list data, loading/error status, and pagination totals for the listing page" }
  ],
  "newRoutes": [
    { "path": "/benefits", "component": "BenefitsList (Loadable)", "auth": true, "description": "Benefits listing page" },
    { "path": "/benefits/:benefitId", "component": "Placeholder / NotFoundPage", "auth": true, "description": "Benefit detail view — out of scope; route reserved" }
  ],
