      "status": "ASSUMED",
      "endpoint": "/incentives/api/v1/benefits/custom-fields",
      "method": "GET",
      "requestPayload": { "programId": "string (required)", "sortBy": "updatedOn", "sortOrder": "ASC | DESC", "status": "ACTIVE" },
      "responsePayload": {
        "status": "success",
        "code": 200,
        "data": {
          "customFields": [{ "id": "string", "name": "Disclaimer", "dataType": "STRING", "programId": "string", "updatedBy": "Dev Patel", "updatedOn": "2024-06-12T00:00:00Z", "status": "ACTIVE" }],
          "totalCount": 5
