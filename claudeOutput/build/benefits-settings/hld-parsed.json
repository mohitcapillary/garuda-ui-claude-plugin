{
  "feature": "benefits-settings",
  "featureName": "Benefits Settings",
  "prdSource": "claudeOutput/filteredPrd/benefits-settings-spec.md",
  "inScope": [
    "Display a Settings > Benefits page accessible via the left navigation sidebar",
    "Show two sections: Custom fields (top) and Categories (bottom)",
    "Full CRUD for custom fields: list, create (Name + Data type), edit (Name only; Data type read-only), delete with confirmation",
    "Full CRUD for categories: list, create (Name input), edit (Name update), delete with confirmation",
    "Uniqueness enforcement for both entity types per program",
    "Soft deletion (name reuse enabled after deletion)",
    "Sortable Last updated on column in both tables",
    "Empty state display when no items exist",
    "Inline validation: empty name, duplicate name detection",
    "Delete confirmation dialog before executing deletion"
  ],
  "outOfScope": [
    "Assigning custom fields or categories to individual benefits",
    "Bulk import/export",
    "Custom field ordering or drag-and-drop reordering",
    "Custom field validation rules beyond data type",
    "Cross-program sharing of custom fields or categories"
  ],
  "newComponents": [
    { "name": "BenefitsSettings", "tier": "page", "location": "app/components/pages/BenefitsSettings/BenefitsSettings.js", "purpose": "Root container for the Benefits Settings page. Redux-connected. Renders both settings sections." },
    { "name": "BenefitsSettingsLoadable", "tier": "page", "location": "app/components/pages/BenefitsSettings/Loadable.js", "purpose": "Async loadable wrapper with HOC composition (auth, translations)." },
    { "name": "CustomFieldsSection", "tier": "organism", "location": "app/components/organisms/CustomFieldsSection/index.js", "purpose": "Renders the Custom Fields listing table, section header, and manages create/edit/delete modal state locally." },
    { "name": "CategoriesSection", "tier": "organism", "location": "app/components/organisms/CategoriesSection/index.js", "purpose": "Renders the Categories listing table, section header, and manages create/edit/delete modal state locally." },
    { "name": "BenefitsSettingsModal", "tier": "molecule", "location": "app/components/molecules/BenefitsSettingsModal/index.js", "purpose": "Shared modal component for create/edit operations on both custom fields and categories." },
    { "name": "DeleteConfirmModal", "tier": "molecule", "location": "app/components/molecules/DeleteConfirmModal/index.js", "purpose": "Reusable confirmation dialog for delete operations." }
  ],
  "modifiedComponents": [
    { "name": "Cap constants.js", "location": "app/components/pages/Cap/constants.js", "change": "Add BENEFITS_SETTINGS_URL = '/settings/benefits' and add Benefits item to getSettingsMenuData()." },
    { "name": "App routes.js", "location": "app/components/pages/App/routes.js", "change": "Add route { path: '/settings/benefits', component: lazy(() => import('../BenefitsSettings')) }." },
    { "name": "app/services/api.js", "location": "app/services/api.js", "change": "Add 8 new API methods for Benefits Settings CRUD." }
  ],
  "newReduxDomains": [
    {
      "domain": "benefits-settings",
      "injectKey": "${CURRENT_APP_NAME}-benefits-settings",
      "reducer": "BenefitsSettings/reducer.js",
      "saga": "BenefitsSettings/saga.js",
      "purpose": "Stores custom fields list, categories list, and API status fields for both sections."
    }
  ],
  "newRoutes": [
    { "path": "/settings/benefits", "component": "BenefitsSettingsLoadable", "authRequired": true, "description": "Benefits Settings page" }
  ],
  "sharedUtilities": [
    { "name": "messages.js", "location": "app/components/pages/BenefitsSettings/messages.js", "new": true, "purpose": "react-intl message descriptors for all user-visible strings." }
  ],
